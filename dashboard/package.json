{
  "name": "finanzas-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "tsc -b && vite build --mode production",
    "build:qa": "tsc -b && vite build --mode qa",
    "deploy:prod": "npm run build:prod && npx wrangler@4.98.0 pages deploy dist --project-name finanzas-dashboard --branch main",
    "deploy:qa": "npm run build:qa && npx wrangler@4.98.0 pages deploy dist --project-name finanzas-dashboard --branch qa",
    "preview": "vite preview"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@remixicon/react": "^4.9.0",
    "@tremor/react": "^3.18.7",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17"
  }
}
