    {
      "name": "07 Recibos",
      "item": [
        {
          "name": "Subir recibo (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-admin-key",
                "value": "{{admin_key}}"
              }
            ],
            "url": "{{base_url}}/api/receipts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chat_id\": \"{{chat_id}}\",\n  \"transaction_id\": \"{{transaction_id}}\",\n  \"file_name\": \"recibo-postman.jpg\",\n  \"content_type\": \"image/jpeg\",\n  \"base64\": \"{{receipt_base64}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const value = get(data, 'receipt.id');",
                  "if (value) {",
                  "  pm.environment.set('receipt_id', value);",
                  "}",
                  "function get(obj, path) {",
                  "  return path.split('.').reduce((acc, key) => acc && acc[key], obj);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Descargar archivo de recibo",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/receipts/{{receipt_id}}/file"
          }
        }
      ]
    }
