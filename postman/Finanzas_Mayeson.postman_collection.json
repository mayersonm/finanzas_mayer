{
  "info": {
    "name": "Finanzas Mayeson API",
    "description": "Coleccion para probar el Worker D1 de Finanzas Mayeson.\n\nFlujo recomendado:\n1. Selecciona el environment Finanzas Mayeson.\n2. Llena login_email y login_password, o llena auth_token con dashboard_api_key.\n3. Ejecuta Auth / Login para guardar session_token y auth_token automaticamente.\n4. Para endpoints admin-only, llena admin_key.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('auth_token') && pm.environment.get('dashboard_api_key')) {",
          "  pm.environment.set('auth_token', pm.environment.get('dashboard_api_key'));",
          "}",
          "if (!pm.environment.get('today')) {",
          "  pm.environment.set('today', new Date().toISOString().slice(0, 10));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 Salud y Auth",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health",
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/login",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"{{login_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "  pm.environment.set('session_token', data.token);",
                  "  pm.environment.set('auth_token', data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Validar sesion",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/session"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/logout"
          }
        },
        {
          "name": "Cambiar clave",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{login_password}}\",\n  \"newPassword\": \"{{new_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
