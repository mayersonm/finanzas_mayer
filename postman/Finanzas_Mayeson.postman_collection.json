    {
      "name": "02 Movimientos",
      "item": [
        {
          "name": "Listar movimientos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/transactions?chat_id={{chat_id}}&limit={{limit}}&q={{search}}&category={{category}}"
          }
        },
        {
          "name": "Crear movimiento (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-admin-key",
                "value": "{{admin_key}}"
              }
            ],
            "url": "{{base_url}}/api/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chat_id\": \"{{chat_id}}\",\n  \"fecha\": \"{{today}}\",\n  \"hora\": \"12:00\",\n  \"tipo\": \"gasto\",\n  \"desc\": \"Prueba Postman\",\n  \"cat\": \"otro\",\n  \"monto\": 1,\n  \"currency\": \"PEN\",\n  \"payment_method\": \"debito\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const value = get(data, 'transaction.id');",
                  "if (value) {",
                  "  pm.environment.set('transaction_id', value);",
                  "}",
                  "function get(obj, path) {",
                  "  return path.split('.').reduce((acc, key) => acc && acc[key], obj);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Editar movimiento",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/transactions/{{transaction_id}}?chat_id={{chat_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"{{today}}\",\n  \"hora\": \"12:00\",\n  \"tipo\": \"gasto\",\n  \"desc\": \"Prueba Postman editada\",\n  \"cat\": \"supermercado\",\n  \"monto\": 1.5,\n  \"currency\": \"PEN\",\n  \"payment_method\": \"debito\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Eliminar movimiento",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/transactions/{{transaction_id}}?chat_id={{chat_id}}"
          }
        },
        {
          "name": "Cambiar categoria (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-admin-key",
                "value": "{{admin_key}}"
              }
            ],
            "url": "{{base_url}}/api/transactions/category",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chat_id\": \"{{chat_id}}\",\n  \"id\": \"{{transaction_id}}\",\n  \"category\": \"supermercado\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
